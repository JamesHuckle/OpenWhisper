OPENAI_API_KEY=your_openai_api_key_here
OPENWHISPER_MODEL=gpt-4o-mini-transcribe
OPENWHISPER_POLISH_MODEL=gpt-5.4

# Optional override when autodetection is not desired.
# OPENWHISPER_WORKER_SRC=../../worker/src
# Optional override for Python executable (for example: python3, /usr/bin/python3).
# OPENWHISPER_PYTHON_BIN=python3

# Tauri updater signing (required for releases). Run: .\scripts\setup-updater-keys.ps1
TAURI_SIGNING_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

Set to 1 to release without notifying existing users to upgrade (no latest.json uploaded)
OPENWHISPER_SKIP_UPDATE_NOTIFY=1
