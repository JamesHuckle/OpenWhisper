{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenWhisper",
  "version": "0.2.6",
  "identifier": "com.openwhisper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenWhisper",
        "width": 92,
        "height": 28,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "alwaysOnTop": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["binaries/*"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0MjFGNjI4QjZBODYyODkKUldTSllxaTJLUFloRktiNHRpRnQ5UTN2TjlxaG9Gd2ZMaEFGcTBPa3lOYksrdWJSYy84c1AwYnIK",
      "endpoints": [
        "https://github.com/JamesHuckle/OpenWhisper/releases/latest/download/latest.json"
      ]
    }
  }
}

